<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Скорость (левый верхний угол) -->
    <TextView
        android:id="@+id/tvSpeed"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="0"
        android:textColor="#FFFFFF"
        android:textSize="96sp"
        android:textStyle="bold"
        android:fontFamily="monospace"
        android:layout_margin="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="КМ/Ч"
        android:textColor="#AAAAAA"
        android:textSize="18sp"
        android:layout_marginStart="24dp"
        app:layout_constraintTop_toBottomOf="@id/tvSpeed"
        app:layout_constraintStart_toStartOf="parent" />

    <!-- Радар (центр) -->
    <com.hudspeed.android.ui.RadarView
        android:id="@+id/radarView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar"
        app:layout_constraintStart_toEndOf="@id/tvSpeed"
        app:layout_constraintEnd_toStartOf="@id/rightPanel"
        android:layout_margin="4dp" />

    <!-- Правая панель: иконка камеры + расстояние -->
    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="140dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottomBar">

        <ImageView
            android:id="@+id/ivCameraIcon"
            android:layout_width="80dp"
            android:layout_height="64dp"
            android:src="@drawable/ic_camera"
            android:visibility="invisible"
            android:layout_marginBottom="12dp" />

        <!-- Иконки одобрений (палец) — декоративные -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👍" android:textSize="20sp" android:layout_marginEnd="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👍" android:textSize="20sp" android:layout_marginEnd="4dp" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="👍" android:textSize="20sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCameraDistance"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Камер нет"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:gravity="center"
            android:layout_marginTop="16dp" />

    </LinearLayout>

    <!-- Нижняя панель с кнопками -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:orientation="horizontal"
        android:background="#111111"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnCameraExists"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Камера есть"
            android:textSize="14sp"
            android:backgroundTint="#2ECC40"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnEdit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.6"
            android:text="Править"
            android:textSize="14sp"
            android:backgroundTint="#444444"
            android:layout_margin="4dp" />

        <Button
            android:id="@+id/btnNoCameras"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="Камер нет"
            android:textSize="14sp"
            android:backgroundTint="#CC0000"
            android:layout_margin="4dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
