<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- ── Транспорт ─────────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="Транспорт">

        <ListPreference
            android:key="vehicle_type"
            android:title="Тип транспортного средства"
            android:summary="%s"
            android:entries="@array/vehicle_type_entries"
            android:entryValues="@array/vehicle_type_values"
            android:defaultValue="car" />

    </PreferenceCategory>

    <!-- ── Скорость ───────────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="Скорость">

        <ListPreference
            android:key="speed_limit"
            android:title="Порог превышения скорости"
            android:summary="Скорость при которой экран краснеет"
            android:entries="@array/speed_limit_entries"
            android:entryValues="@array/speed_limit_values"
            android:defaultValue="60" />

        <SeekBarPreference
            android:key="speed_tolerance"
            android:title="Допустимое превышение"
            android:summary="Оповещать при превышении на X км/ч (0 = строго)"
            app:min="0"
            android:max="30"
            android:defaultValue="10"
            app:showSeekBarValue="true" />

        <ListPreference
            android:key="speed_offset"
            android:title="Корректировка GPS-скорости"
            android:summary="Синхронизация с автомобильным спидометром (+/- км/ч)"
            android:entries="@array/speed_offset_entries"
            android:entryValues="@array/speed_offset_values"
            android:defaultValue="0" />

        <SeekBarPreference
            android:key="speed_calibration"
            android:title="Калибровка спидометра"
            android:summary="Масштаб GPS-скорости, %"
            app:min="80"
            android:max="120"
            android:defaultValue="100"
            app:showSeekBarValue="true" />

    </PreferenceCategory>

    <!-- ── Оповещения ────────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="Оповещения">

        <ListPreference
            android:key="alert_distance"
            android:title="Дистанция оповещения о камере"
            android:summary="%s"
            android:entries="@array/alert_distance_entries"
            android:entryValues="@array/alert_distance_values"
            android:defaultValue="1000" />

        <SwitchPreferenceCompat
            android:key="voice_enabled"
            android:title="Голосовые оповещения"
            android:defaultValue="true" />

        <SeekBarPreference
            android:key="voice_volume"
            android:title="Громкость оповещений"
            android:summary="Уровень громкости голоса, %"
            app:min="10"
            android:max="100"
            android:defaultValue="100"
            app:showSeekBarValue="true"
            android:dependency="voice_enabled" />

        <SwitchPreferenceCompat
            android:key="voice_audio_focus"
            android:title="Приглушать музыку"
            android:summary="Снижать громкость других приложений во время оповещения"
            android:defaultValue="true"
            android:dependency="voice_enabled" />

        <SwitchPreferenceCompat
            android:key="voice_camera_cleared"
            android:title="Проговаривать «Камер нет»"
            android:summary="Сообщать, когда камера осталась позади"
            android:defaultValue="false"
            android:dependency="voice_enabled" />

        <Preference
            android:key="tts_voice"
            android:title="Голос озвучивания"
            android:summary="По умолчанию"
            android:dependency="voice_enabled" />

        <Preference
            android:key="voice_test"
            android:title="Проверить голос"
            android:summary="Воспроизвести тестовое оповещение"
            android:dependency="voice_enabled" />

    </PreferenceCategory>

    <!-- ── Радар ──────────────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="Радар">

        <ListPreference
            android:key="radar_range"
            android:title="Радиус радара"
            android:summary="%s"
            android:entries="@array/radar_range_entries"
            android:entryValues="@array/radar_range_values"
            android:defaultValue="1500" />

    </PreferenceCategory>

    <!-- ── База камер ─────────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="База камер">

        <Preference
            android:key="camera_count"
            android:title="Камер в базе"
            android:summary="Загрузка..." />

        <Preference
            android:key="update_cameras"
            android:title="Обновить ближайшие камеры"
            android:summary="Обновить камеры в радиусе 10 км (требует GPS)" />

        <Preference
            android:key="download_offline"
            android:title="Скачать базу офлайн (Россия / Беларусь)"
            android:summary="Загрузить всю страну для работы без интернета" />

        <SwitchPreferenceCompat
            android:key="auto_update_enabled"
            android:title="Автообновление базы"
            android:summary="Автоматически обновлять базу по расписанию"
            android:defaultValue="false" />

        <ListPreference
            android:key="auto_update_interval"
            android:title="Частота автообновления"
            android:summary="%s"
            android:entries="@array/auto_update_entries"
            android:entryValues="@array/auto_update_values"
            android:defaultValue="7"
            android:dependency="auto_update_enabled" />

        <Preference
            android:key="auto_update_status"
            android:title="Последнее автообновление"
            android:summary="Не выполнялось"
            android:enabled="false" />

    </PreferenceCategory>

    <!-- ── Фоновый режим ─────────────────────────────────────────────────── -->
    <PreferenceCategory android:title="Фоновый режим">

        <SwitchPreferenceCompat
            android:key="overlay_enabled"
            android:title="Мини-радар поверх приложений"
            android:summary="При сворачивании показывает мини-радар поверх любых приложений"
            android:defaultValue="true" />

    </PreferenceCategory>

</PreferenceScreen>
