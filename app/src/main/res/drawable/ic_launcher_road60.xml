<?xml version="1.0" encoding="utf-8"?>
<!--
  Viewport 108×108.

  "6" is built from three sub-paths (nonZero winding):
    1. CW  — L-bar + top-cap (the hook)
    2. CW  — outer bottom circle  (center 36,66 r=19)
    3. CCW — inner hole           (center 38,66 r=10)
  The CCW inner cancels the CW outer only inside the bowl → donut hole.
  The L-bar (x=20–28) just touches inner circle's left edge (x=28) so no
  unwanted cancellation in the bar region.

  "0" is built from two sub-paths:
    1. CW  — outer ellipse  (cx=75 cy=54 rx=14 ry=34)
    2. CCW — inner ellipse  (cx=75 cy=54 rx=7  ry=26)
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Dark background — slight centre-top glow, black edges -->
    <path android:pathData="M0,0 H108 V108 H0 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="radial"
                android:centerX="54"
                android:centerY="44"
                android:gradientRadius="72"
                android:startColor="#262626"
                android:endColor="#060606" />
        </aapt:attr>
    </path>

    <!-- Left road dashes  (4 white horizontal bars) -->
    <path
        android:fillColor="#F0FFFFFF"
        android:pathData="M7,20 H19 V28 H7 Z
                          M7,40 H19 V48 H7 Z
                          M7,60 H19 V68 H7 Z
                          M7,80 H19 V88 H7 Z" />

    <!-- Right road dashes -->
    <path
        android:fillColor="#F0FFFFFF"
        android:pathData="M89,20 H101 V28 H89 Z
                          M89,40 H101 V48 H89 Z
                          M89,60 H101 V68 H89 Z
                          M89,80 H101 V88 H89 Z" />

    <!-- "60" — green top-to-bottom gradient, nonZero winding for holes -->
    <path
        android:fillType="nonZero"
        android:pathData="
          M20,20 H50 A7,7 0 0,1 56,27 A7,7 0 0,1 50,34 H28 V66 H20 Z
          M36,47 A19,19 0 1,1 36,85 A19,19 0 1,1 36,47 Z
          M38,56 A10,10 0 1,0 38,76 A10,10 0 1,0 38,56 Z
          M75,20 A14,34 0 1,1 75,88 A14,34 0 1,1 75,20 Z
          M75,28 A7,26  0 1,0 75,80 A7,26  0 1,0 75,28 Z">
        <aapt:attr name="android:fillColor">
            <gradient
                android:type="linear"
                android:startX="54" android:startY="20"
                android:endX="54"   android:endY="88"
                android:startColor="#77EE33"
                android:endColor="#166600" />
        </aapt:attr>
    </path>

    <!-- Gloss highlight: bright top-left on the "60" -->
    <path
        android:fillColor="#50FFFFFF"
        android:fillType="nonZero"
        android:pathData="M20,20 H28 V44 H20 Z
                          M20,20 H50 A7,7 0 0,1 56,27 L50,27 H20 Z
                          M63,20 H89 V27 H63 Z
                          M63,20 H69 V54 H63 Z" />

</vector>
